{
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": true
      }
    },
    "staging": {
      "developmentClient": false,
      "channel": "staging",
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "distribution": "store",
      "channel": "production",
      "android": {
        "buildType": "app-bundle",
        "autoIncrement": true
      },
      "ios": {
        "autoIncrement": true,
        "image": "latest"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "track": "production"
      },
      "ios": {
        "appleId": "sharan.gohar@icloud.com",
        "ascAppId": "1526488093",
        "appleTeamId": "GDFK7MVY6P"
      }
    }
  },
  "cli": {
    "version": ">= 0.43.0",
    "appVersionSource": "remote"
  }
}
