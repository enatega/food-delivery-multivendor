# Hosted demo API (default). For a licensed local API use http://localhost:8001/ and ws://localhost:8001/
NEXT_PUBLIC_SERVER_URL="https://aws-server-v2.enatega.com/"
NEXT_PUBLIC_WS_SERVER_URL="wss://aws-server-v2.enatega.com/"

# Required for Google Maps / address UX in the browser
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional — Google login (may also come from API configuration)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Optional — EmailJS helpers
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
